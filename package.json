{
  "name": "nova-force",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -n next,inngest -c cyan,magenta --kill-others-on-fail \"next dev --webpack\" \"inngest dev -u http://localhost:3000/api/inngest --poll-interval 30\"",
    "dev:next": "next dev --webpack",
    "dev:inngest": "inngest dev -u http://localhost:3000/api/inngest --poll-interval 30",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pipeline:manifest": "tsx scripts/pipeline/generate-manifest.ts",
    "pipeline:validate": "tsx scripts/pipeline/validate-manifest.ts",
    "pipeline:generate": "tsx scripts/pipeline/generate-scenes.ts",
    "pipeline:stitch": "tsx scripts/pipeline/stitch-episode.ts",
    "pipeline:image": "tsx scripts/pipeline/generate-images.ts",
    "content:lint": "tsx scripts/lint-content.ts",
    "db:seed-locations": "tsx scripts/seed-locations.ts",
    "gen:style-thumbnails": "tsx scripts/generate-style-thumbnails.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@runwayml/sdk": "^3.19.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.2.6",
    "marked": "^18.0.3",
    "next": "^16.2.4",
    "openai": "^6.34.0",
    "postgres": "^3.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "inngest-cli": "^1.19.1",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "inngest-cli"
    ]
  }
}
